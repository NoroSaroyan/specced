# Copy to terraform.tfvars and adjust. Auth comes from the GITHUB_TOKEN env var.
github_owner = "NoroSaroyan"
repo_name    = "specced"
visibility   = "public"

# Solo repo: keep reviews off and admins unenforced. For a team:
# required_approving_reviews = 1
# enforce_admins             = true

