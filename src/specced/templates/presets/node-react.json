{
  "name": "node-react",
  "description": "React SPA (Vite + eslint + vitest).",
  "language": "node",
  "detect": { "any_frameworks": ["react", "vite"], "priority": 45 },
  "make": {
    "fmt": "npm run format --if-present",
    "lint": "npm run lint",
    "test": "npm run test --if-present",
    "build": "npm run build"
  },
  "tracks": ["frontend"],
  "mcp_servers": ["github", "context7", "playwright"],
  "rules": ["frontend/components.md", "frontend/state.md", "frontend/data-fetching.md"],
  "code_review": ["01-components.md", "02-state.md", "03-accessibility.md", "04-tests.md"]
}
